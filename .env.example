# Example environment configuration. Copy to `.env.local` (gitignored) and fill in.
# NEVER commit real secret values. `.env.local` / `.env*` are ignored by git.

# --- Admin credentials -------------------------------------------------------
# Admin authentication is verified SERVER-SIDE against the D1 `admin_users`
# table (PBKDF2 hash). No password or hash is shipped to the browser.
#
# The admin account is provisioned/rotated by the seed generator, which reads
# these at seed time and writes ONLY the PBKDF2 hash into the migration SQL
# (the plaintext is never emitted). To rotate: set ADMIN_PASSWORD, regenerate
# the seed (`node --env-file=.env.local scripts/generate-seed.mjs`), and
# re-apply migrations to local D1.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Sessions ----------------------------------------------------------------
# Reserved secret for future cookie signing. The current session scheme uses a
# random opaque token whose SHA-256 hash is stored in the D1 `sessions` table,
# so no secret is shipped to the browser.
SESSION_SECRET=replace-with-a-long-random-string
